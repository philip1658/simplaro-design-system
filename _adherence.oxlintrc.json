{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/chat/**",
              "components/content/**",
              "components/core/**",
              "components/decor/**",
              "components/navigation/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Mono|Quicksand))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Mono, Quicksand."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|arrow|href|target|onClick|disabled|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, arrow, href, target, onClick, disabled, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:cta|light|glass|dark)$/]",
        "message": "<Button> variant must be one of 'cta' | 'light' | 'glass' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|comic|style|children|key|ref|className|style|children)$/]",
        "message": "<ChatMessage> doesn't accept that prop. Declared props: role, comic, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:bot|user)$/]",
        "message": "<ChatMessage> role must be one of 'bot' | 'user'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:boxed|tone|style|children|key|ref|className|style|children)$/]",
        "message": "<CheckItem> doesn't accept that prop. Declared props: boxed, tone, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckItem'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|onTerra|onDark)$/]",
        "message": "<CheckItem> tone must be one of 'light' | 'onTerra' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|children|key|ref|className|style|children)$/]",
        "message": "<CheckPill> doesn't accept that prop. Declared props: style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FaqItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:question|last|defaultOpen|style|children|key|ref|className|style|children)$/]",
        "message": "<FaqItem> doesn't accept that prop. Declared props: question, last, defaultOpen, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|tone|style|children|key|ref|className|style|children)$/]",
        "message": "<Kicker> doesn't accept that prop. Declared props: number, tone, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:terra|onTerra|onDark)$/]",
        "message": "<Kicker> tone must be one of 'terra' | 'onTerra' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KompassTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|style|children|key|ref|className|style|children)$/]",
        "message": "<KompassTile> doesn't accept that prop. Declared props: number, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='LabelBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|style|children|key|ref|className|style|children)$/]",
        "message": "<LabelBadge> doesn't accept that prop. Declared props: tone, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='LabelBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:peach|onTerra|onDark)$/]",
        "message": "<LabelBadge> tone must be one of 'peach' | 'onTerra' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PackageCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|badge|title|subtitle|features|price|style|key|ref|className|style|children)$/]",
        "message": "<PackageCard> doesn't accept that prop. Declared props: variant, badge, title, subtitle, features, price, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PackageCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:terra|dark)$/]",
        "message": "<PackageCard> variant must be one of 'terra' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuoteCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|quote|attribution|style|key|ref|className|style|children)$/]",
        "message": "<QuoteCard> doesn't accept that prop. Declared props: logoSrc, quote, attribution, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|title|last|style|children|key|ref|className|style|children)$/]",
        "message": "<ServiceRow> doesn't accept that prop. Declared props: number, title, last, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteFooter'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|logoHeight|address|email|copyright|onTop|style|key|ref|className|style|children)$/]",
        "message": "<SiteFooter> doesn't accept that prop. Declared props: logoSrc, logoHeight, address, email, copyright, onTop, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|logoHeight|links|active|ctaLabel|ctaHref|onNavigate|style|key|ref|className|style|children)$/]",
        "message": "<SiteHeader> doesn't accept that prop. Declared props: logoSrc, logoHeight, links, active, ctaLabel, ctaHref, onNavigate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeechBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:tail|comic|onClick|style|children|key|ref|className|style|children)$/]",
        "message": "<SpeechBubble> doesn't accept that prop. Declared props: tail, comic, onClick, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeechBubble'] > JSXAttribute[name.name='tail'] > Literal[value!=/^(?:bottom-left|right|left)$/]",
        "message": "<SpeechBubble> tail must be one of 'bottom-left' | 'right' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|badge|title|style|children|key|ref|className|style|children)$/]",
        "message": "<StepCard> doesn't accept that prop. Declared props: number, badge, title, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeamCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|name|role|photoHeight|style|children|key|ref|className|style|children)$/]",
        "message": "<TeamCard> doesn't accept that prop. Declared props: src, alt, name, role, photoHeight, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Twinkle'] > JSXAttribute > JSXIdentifier[name!=/^(?:left|right|top|bottom|size|delay|duration|color|style|key|ref|className|style|children)$/]",
        "message": "<Twinkle> doesn't accept that prop. Declared props: left, right, top, bottom, size, delay, duration, color, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
